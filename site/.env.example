# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Anthropic (contract generation via Claude Haiku) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- App ---
NEXT_PUBLIC_APP_URL=https://ambr.run

# --- Receiving wallet (Base L2) ---
NEXT_PUBLIC_WALLET_ADDRESS=0x...

# --- cNFT (Base L2) ---
CNFT_CONTRACT_ADDRESS=0x...
CNFT_MINTER_PRIVATE_KEY=0x...
# BaseScan API key for `npx hardhat verify --network base ...` (get free at https://basescan.org/myapikey)
BASESCAN_API_KEY=

# --- Stripe ---
# Live or test secret key (sk_live_... for prod, sk_test_... for dev)
STRIPE_SECRET_KEY=sk_...
# Signing secret for /api/v1/stripe/webhook signature verification
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (outbound email, DKIM-signed from ambr.run) ---
RESEND_API_KEY=re_...

# --- Admin ---
# Bearer token required by /api/v1/admin/* endpoints (64-char hex)
ADMIN_SECRET=

# --- Ops Agent bridge (Google Apps Script) ---
# Deployed web-app URL and API key used by /api/health + /api/ops/*
OPS_BASE=https://script.google.com/macros/s/AKfycb.../exec
OPS_KEY=amb-ops-...
